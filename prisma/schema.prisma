// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String?    // Optional for OAuth
  role      String     @default("CUSTOMER") // "ADMIN" or "CUSTOMER"
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  orders Order[]
  accounts Account[]
  sessions Session[]

  @@map("users")
}

// NextAuth related tables
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Product model
model Product {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String
  price       Float
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])
  categoryName String    @default("Software") // Fallback string category
  stock       Int        @default(0)
  image       String?
  badge       String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  licenseKeys LicenseKey[]
  orderItems  OrderItem[]

  @@index([categoryId])
  @@index([active])
  @@map("products")
}

// Category model
model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  icon      String?   // Icon name or emoji
  active    Boolean   @default(true)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@map("categories")
}

// License Key model
model LicenseKey {
  id        String   @id @default(cuid())
  key       String   @unique
  status    String   @default("AVAILABLE") // "AVAILABLE", "SOLD", "REVOKED"
  productId String
  orderId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  order     Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([status])
  @@map("license_keys")
}

// Order model
model Order {
  id            String   @id @default(cuid())
  userId        String
  total         Float
  status        String   @default("PENDING") // "PENDING", "PAID", "FAILED", "CANCELED"
  paymentMethod String?  // "stripe", "paypal"
  paymentId     String?  // Stripe Payment Intent ID or PayPal Order ID
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         OrderItem[]
  licenseKeys   LicenseKey[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

// Order Item model
model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  price     Float    // Price at time of purchase
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  // Relations
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// Coupon model
model Coupon {
  id        String   @id @default(cuid())
  code      String   @unique
  discount  Float    // Percentage (0-100) or fixed amount
  type      String   // "percentage" or "fixed"
  maxUses   Int?
  uses      Int      @default(0)
  active    Boolean  @default(true)
  expiresAt DateTime?
  createdAt DateTime @default(now())

  @@index([code])
  @@index([active])
  @@map("coupons")
}

// App Configuration model
model AppConfig {
  id             String   @id @default("global")
  heroTitle      String   @default("EL ESTÁNDAR DE ÉLITE EN LICENCIAS DIGITALES")
  heroSubtitle   String   @default("INFRAESTRUCTURA PREMIUM")
  heroOffersFrom String   @default("29.99")
  heroTitleSize  String   @default("8xl") // "7xl", "8xl", "9xl"
  
  // Payment Config
  paypalClientId      String?
  paypalSecret        String?
  mercadopagoAccessToken String?
  coinpalApiKey      String?
  coinpalMerchantId  String?

  updatedAt      DateTime @updatedAt

  @@map("app_configs")
}
